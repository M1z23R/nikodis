# Nikodis server configuration

# gRPC listen port
NIKODIS_PORT=6390

# Path to auth config file (JSON or YAML). Leave empty to disable auth.
NIKODIS_CONFIG_FILE=/opt/nikodis/config.json

# Broker settings
NIKODIS_MAX_BUFFER_SIZE=10000
NIKODIS_DEFAULT_ACK_TIMEOUT=30s
NIKODIS_MAX_REDELIVERIES=5

# Debug logging (set to true to enable)
NIKODIS_DEBUG_LOG=false
NIKODIS_DEBUG_LOG_DIR=/opt/nikodis/logs/
NIKODIS_DEBUG_LOG_ROTATION=daily
