[Unit]
Description=Nikodis Cache & Message Broker
After=network.target

[Service]
Type=simple
User=nikodis
Group=nikodis
WorkingDirectory=/opt/nikodis
ExecStart=/opt/nikodis/nikodis
EnvironmentFile=/opt/nikodis/.env

Restart=always
RestartSec=3

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

# Logging
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
